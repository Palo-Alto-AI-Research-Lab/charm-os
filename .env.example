# Copy to .env and fill in. NEVER commit a real .env.
# All values below are placeholders.

# --- Paths ---
VAULT_PATH=/path/to/your/markdown/vault
EXAMPLES_PATH=./examples

# --- Embeddings / recall (local-first) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RECALL_SERVER_PORT=8770

# --- Optional LLM provider (leave blank to stay fully local) ---
LLM_PROVIDER=
LLM_API_KEY=YOUR_KEY_HERE

# --- Connectors (optional, all blank by default) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
GMAIL_CLIENT_SECRET_PATH=
